# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public site URL (Vercel production domain)
# NEXT_PUBLIC_APP_URL=https://tu-proyecto.vercel.app

# Admin seed (used by npm run db:seed)
ADMIN_EMAIL=admin@rifacil.com
ADMIN_PASSWORD=rifacil123

# Neon Postgres (required on Vercel — without it local PGlite is used)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Vercel Blob (recommended on Vercel for payment proofs)
# BLOB_READ_WRITE_TOKEN=

# Gmail / SMTP — solo notifica al super admin (rifas de la org plataforma).
# Los clientes organizadores NO reciben correo; revisan su panel /admin.
# Gmail: activa verificación en 2 pasos → Contraseñas de aplicaciones → genera una.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="Rifacil <tu-correo@gmail.com>"
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
